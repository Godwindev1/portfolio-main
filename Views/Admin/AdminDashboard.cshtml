@{
    Layout = "_AdminLayout";
}

<h2>Admin Dashboard</h2>

<div class="admin-grid">
    <a href="/admin/TechnicalArsenal" class="admin-card">Technical Arsenal</a>
    <a href="/admin/Certifications" class="admin-card">Certifications</a>
    <a href="/admin/Testimonial" class="admin-card">Testimonials</a>
    <a href="/admin/Experience" class="admin-card">Experience</a>
    <a href="/admin/CaseStudy/List" class="admin-card">Case Studies</a>
</div>

<style>
.admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.admin-card {
    display: block;
    padding: 20px;
    background: #1e1e2f;
    color: white;
    text-align: center;
    text-decoration: none;
    border-radius: 10px;
    transition: 0.2s;
}

.admin-card:hover {
    background: #2a2a40;
    transform: translateY(-3px);
}
</style>
