// ── Artifact helpers ─────────────────────────────────────────────────────────

/**
 * param {string} containerId
 * param {string} prefix       - e.g. "Documents", "Videos", "Screenshots"
 * param {string} tag          - display label prefix e.g. "DOC"
 * param {string} accept       - file input accept string
 * param {boolean} isImage     - whether to wire up local image preview
 */
function addUploadCard(containerId, prefix, tag, accept, isImage = false) {
    const c = document.getElementById(containerId);
    const i = nextIdx(c);
    const previewAttr = isImage
        ? `onchange="previewLocal(this, null, this.closest('.card'))"`
        : '';
    c.insertAdjacentHTML('beforeend', `
        <div class="card upload" data-idx="${i}">
            <div class="card-header">
                <span class="card-index">${tag}_${i}</span>
                <button type="button" class="btn-remove" onclick="removeCard(this)">× REMOVE</button>
            </div>
            <input type="hidden" name="${prefix}[${i}].Id" value="" />
            <div class="form-group">
                <label>LABEL</label>
                <input name="${prefix}[${i}].Label" class="f-input" placeholder="Descriptive label..." />
            </div>
            <div class="form-group">
                <label>FILE</label>
                <input type="file" name="${prefix}[${i}].File"
                       class="f-file" accept="${accept}" ${previewAttr} />
            </div>
        </div>`);
}

/**
 * param {string} containerId
 * param {string} prefix  - e.g. "Repos", "LiveDemos", "Links"
 * param {string} tag
 */
function addLinkCard(containerId, prefix, tag) {
    const c = document.getElementById(containerId);
    const i = nextIdx(c);
    c.insertAdjacentHTML('beforeend', `
        <div class="card link" data-idx="${i}">
            <input type="hidden" name="${prefix}[${i}].Id" value="" />
            <div class="card-header">
                <div class="form-row" style="flex:1">
                    <div class="form-group">
                        <label>LABEL</label>
                        <input name="${prefix}[${i}].Label" class="f-input" placeholder="Descriptive label..." />
                    </div>
                    <div class="form-group">
                        <label>URL</label>
                        <input name="${prefix}[${i}].Url" class="f-input" placeholder="https://..." />
                    </div>
                </div>
                <button type="button" class="btn-remove" onclick="removeCard(this)">×</button>
            </div>
        </div>`);
}
