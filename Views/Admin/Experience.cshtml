@model List<Portfolio.Models.Experience>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Experience // CMS";
}

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="acms-shell">

  <!-- ── HEADER ── -->
  <div class="acms-header">
    <div class="acms-header-left">
      <span class="acms-breadcrumb">ADMIN // ARCHIVE_03</span>
      <h1 class="acms-page-title">Experience_Log</h1>
      <p> No of Items: @Model.Count</p>
    </div>
    <button class="acms-btn-primary" onclick="openPanel(null)">
      <span class="btn-icon">+</span> NEW_ENTRY
    </button>
  </div>

  <!-- ── ALERTS ── -->
  @if (TempData["Success"] != null)
  {
    <div class="acms-alert acms-alert--ok">
      <span class="alert-dot"></span> @TempData["Success"]
    </div>
  }
  @if (TempData["Error"] != null)
  {
    <div class="acms-alert acms-alert--err">
      <span class="alert-dot"></span> @TempData["Error"]
    </div>
  }

  <!-- ── ENTRY LIST ── -->
  <div class="exp-admin-list">
    @if (!Model.Any())
    {
      <div class="acms-empty">
        <span class="empty-code">[ NULL ]</span>
        <p>No experience entries found. Add your first entry.</p>
      </div>
    }

    @foreach (var exp in Model)
    {
      <div class="exp-admin-card">
        <div class="exp-admin-card__period">@exp.Period</div>

        <div class="exp-admin-card__main">
          <div class="exp-admin-card__role">@exp.Role</div>
          <div class="exp-admin-card__company">@exp.Company</div>
          <p class="exp-admin-card__desc">@exp.Description</p>

          <div class="exp-admin-card__meta">
            <span class="meta-pill">
              <span class="meta-label">RESPONSIBILITIES</span>
              <span class="meta-count">@exp.Responsibilities.Count</span>
            </span>
            <span class="meta-pill">
              <span class="meta-label">TAGS</span>
              <span class="meta-count">@exp.Tags.Count</span>
            </span>
          </div>

          <div class="exp-admin-card__tags">
            @foreach (var tag in exp.Tags.Take(5))
            {
              <span class="tag">@tag</span>
            }
            @if (exp.Tags.Count > 5)
            {
              <span class="tag tag--more">+@(exp.Tags.Count - 5)</span>
            }
          </div>
        </div>

        <div class="exp-admin-card__actions">
          <button class="acms-btn-icon" onclick='openPanel(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(exp)))'>
            ✦ EDIT
          </button>
          @{/* unimplemented At the Moment in controllers*/ }
          <form asp-action="DeleteExperience" asp-controller="Admin" asp-area="Admin"
                method="post" style="display:inline;"
                onsubmit="return confirm('Delete this entry?')">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@exp.Id" />
            <button type="submit" class="acms-btn-icon acms-btn-icon--danger">⊗ DELETE</button>
          </form>
        </div>
      </div>
    }
  </div>
</div>

<!-- ══ SLIDE-IN PANEL ══ -->
<div class="acms-overlay" id="overlay" onclick="closePanel()"></div>

<aside class="acms-panel" id="editPanel">
  <div class="panel-header">
    <div>
      <span class="panel-eyebrow" id="panelMode">NEW_ENTRY</span>
      <h2 class="panel-title" id="panelTitle">Add Experience</h2>
    </div>
    <button class="panel-close" onclick="closePanel()">✕</button>
  </div>


  <form asp-route="SaveExperience" method="post" class="panel-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" id="f-id"  />

    <div class="form-row form-row--2col">
      <div class="form-group">
        <label class="form-label">PERIOD</label>
        <input class="form-input" name="Period" id="f-period"
               placeholder="e.g. 2023 — Present" />
      </div>
      <div class="form-group">
        <label class="form-label">COMPANY</label>
        <input class="form-input" name="Company" id="f-company"
               placeholder="Company / Client name" />
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">ROLE</label>
      <input class="form-input" name="Role" id="f-role"
             placeholder="e.g. Senior Backend Engineer" />
    </div>

    <div class="form-group">
      <label class="form-label">DESCRIPTION</label>
      <textarea class="form-input form-textarea" name="Description" id="f-desc"
                placeholder="Brief overview of the engagement…" rows="3"></textarea>
    </div>

    <!-- RESPONSIBILITIES -->
    <div class="form-group">
      <label class="form-label">RESPONSIBILITIES</label>
      <div class="chip-builder">
        <div class="chip-list" id="resp-list"></div>
        <div class="chip-input-row">
          <input class="chip-input" id="resp-input"
                 placeholder="Type a responsibility and press Enter…" />
          <button type="button" class="chip-add-btn" onclick="addChip('resp')">ADD</button>
        </div>
      </div>
      <div id="resp-hidden"></div>
    </div>

    <!-- TAGS -->
    <div class="form-group">
      <label class="form-label">TAGS</label>
      <div class="chip-builder">
        <div class="chip-list" id="tags-list"></div>
        <div class="chip-input-row">
          <input class="chip-input" id="tags-input"
                 placeholder="e.g. ASP.NET Core, AWS, PostgreSQL…" />
          <button type="button" class="chip-add-btn" onclick="addChip('tags')">ADD</button>
        </div>
      </div>
      <div id="tags-hidden"></div>
    </div>

    <div class="panel-actions">
      <button type="button" class="acms-btn-ghost" onclick="closePanel()">CANCEL</button>
      <button type="submit" class="acms-btn-primary" id="submitBtn">SAVE_ENTRY</button>
    </div>
  </form>
</aside>



@section Scripts {
<script>
  const state = { resp: [], tags: [] };


  function openPanel(data) {
    const isEdit = data && data.Id;

    document.getElementById('panelMode').textContent  = isEdit ? 'EDIT_ENTRY'       : 'NEW_ENTRY';
    document.getElementById('panelTitle').textContent = isEdit ? 'Edit Experience'   : 'Add Experience';
    document.getElementById('submitBtn').textContent  = isEdit ? 'UPDATE_ENTRY'      : 'SAVE_ENTRY';

    ['f-id','f-period','f-company','f-role','f-desc'].forEach(id =>
      document.getElementById(id).value = '');
    state.resp = []; state.tags = [];
    renderChips('resp'); renderChips('tags');

    if (isEdit) {
      document.getElementById('f-id').value      = data.Id;
      document.getElementById('f-period').value  = data.Period;
      document.getElementById('f-company').value = data.Company;
      document.getElementById('f-role').value    = data.Role;
      document.getElementById('f-desc').value    = data.Description;
      state.resp = [...(data.Responsibilities || [])];
      state.tags = [...(data.Tags || [])];
      renderChips('resp'); renderChips('tags');
    }
    else
    {
      document.getElementById('f-id').value      = null;

    }

    document.getElementById('overlay').classList.add('open');
    document.getElementById('editPanel').classList.add('open');
  }

  function closePanel() {
    document.getElementById('overlay').classList.remove('open');
    document.getElementById('editPanel').classList.remove('open');
  }

  function addChip(type) {
    const input = document.getElementById(`${type}-input`);
    const val   = input.value.trim();
    if (!val) return;
    state[type].push(val);
    input.value = '';
    renderChips(type);
    input.focus();
  }

  function removeChip(type, idx) {
    state[type].splice(idx, 1);
    renderChips(type);
  }

  function renderChips(type) {
    const list   = document.getElementById(`${type}-list`);
    const hidden = document.getElementById(`${type}-hidden`);
    const field  = type === 'resp' ? 'Responsibilities' : 'Tags';
    const cls    = type === 'resp' ? 'chip chip--resp'  : 'chip';

    list.innerHTML = state[type].map((v, i) => `
      <span class="${cls}">
        ${escHtml(v)}
        <button type="button" class="chip-remove"
                onclick="removeChip('${type}', ${i})">✕</button>
      </span>`).join('');

    hidden.innerHTML = state[type].map(v =>
      `<input type="hidden" name="${field}" value="${escHtml(v)}" />`
    ).join('');
  }

  ['resp-input','tags-input'].forEach(id => {
    document.getElementById(id).addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); addChip(id.split('-')[0]); }
    });
  });

  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
}