@model CaseStudyViewModel
@using Portfolio.Models;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@if (Model != null)
{
    <!-- ═══ CASE STUDY SPOTLIGHT ═══ -->
    <section id="case-study">
      <div class="case-study-label">@Model.CaseStudy.Label</div>
      <h2 class="case-study-title">@Html.Raw(Model.CaseStudy.Title)</h2>

      <div class="case-study-body fade-up">
        <div class="case-visual">
          @{ var MediaModel = new MediaViewerModel{ Url = Model.CaseStudy.CoverImageUrl, Type = "Image", label = $"{Model.CaseStudy.Title} cover"};  }
          <partial name="_mediaStreamer" model="@MediaModel" />
        </div>

        <div class="case-narrative">
          <p class="problem-statement">@Html.Raw("\"" + Model.Problem.ProblemStatement + "\"")</p>
          <p class="case-body-text">@Model.CaseStudy.Summary</p>

          <div class="case-metrics">
            @foreach (var metric in Model.CaseStudy.Metrics)
            {
              <div class="case-metric">
                <div class="case-metric-key">@metric.Label</div>
                <div class="case-metric-value">
                  @{
                    var parts = metric.Value.Split(' ');
                    if (parts.Length > 1)
                    {
                      <text>@parts[0] <span class="case-metric-delta">@string.Join(" ", parts.Skip(1))</span></text>
                    }
                    else
                    {
                      <text>@metric.Value</text>
                    }
                  }
                </div>
              </div>
            }
          </div>

          <div onclick="openModal(@Model.CaseStudy.Id)" class="case-cta">
            READ_FULL_ARCHITECTURAL_STORY
            <span class="case-cta-arrow">→</span>
          </div>
          
          @{
                var cs = Model.CaseStudy;
                var links = cs.Artifacts
                    .Where(a => a.Type != ArtifactTypes.ScreenShot && a.Type != ArtifactTypes.ImplementationDetail && a.Type != ArtifactTypes.Videos)
                    .ToList();
            }
            @if (links.Any())
            {
                <div class="modal-artifacts-section" style="border-top: 1px solid var(--border);">
                    <span class="modal-artifacts-label">ARTIFACTS &amp; LINKS</span>
                    <div class="modal-artifacts-links">
                        @foreach (var artifact in links)
                        {
                            if(artifact.Type == ArtifactTypes.Document)
                            {
                                var ArtifactModel = new MediaViewerModel{ Url = artifact.Url, Type = "File", label = artifact.Label}; 
                                <partial name="_mediaStreamer" model="@ArtifactModel" />
                            }
                            else
                            {
                                <a href="@artifact.Url"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="modal-artifact-btn"
                                data-type="@artifact.Type">
                                    @artifact.Label
                                </a>
                            }
                        }
                    </div>
                </div>
            }


        </div>
      </div>
    </section>

    <partial name="_CaseStudyModal" model="@Model" />
}


