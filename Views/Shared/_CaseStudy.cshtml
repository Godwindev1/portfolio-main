@model CaseStudyViewModel

@if (Model != null)
{
    <!-- ═══ CASE STUDY SPOTLIGHT ═══ -->
    <section id="case-study">
      <div class="case-study-label">@Model.caseStudy.Label</div>
      <h2 class="case-study-title">@Html.Raw(Model.caseStudy.Title)</h2>

      <div class="case-study-body fade-up">
        <div class="case-visual">
          <img src="~/images/CaseStudyImage.png" alt="@Model.caseStudy.Title" class="case-visual-img" />
        </div>

        <div class="case-narrative">
          <p class="problem-statement">@Html.Raw("\"" + Model.Problem.ProblemStatement + "\"")</p>
          <p class="case-body-text">@Model.caseStudy.Summary</p>

          <div class="case-metrics">
            @foreach (var metric in Model.caseStudy.Metrics)
            {
              <div class="case-metric">
                <div class="case-metric-key">@metric.Label</div>
                <div class="case-metric-value">
                  @{
                    var parts = metric.Value.Split(' ');
                    if (parts.Length > 1)
                    {
                      <text>@parts[0] <span class="case-metric-delta">@string.Join(" ", parts.Skip(1))</span></text>
                    }
                    else
                    {
                      <text>@metric.Value</text>
                    }
                  }
                </div>
              </div>
            }
          </div>

          <a href="#" class="case-cta">
            READ_FULL_ARCHITECTURAL_STORY
            <span class="case-cta-arrow">→</span>
          </a>
        </div>
      </div>
    </section>
}
