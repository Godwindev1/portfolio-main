## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# dotNet
.dotnet/
.net/

# NuGet Packages
*.nupkg
*.snupkg
.nuget/

# Local History for Visual Studio
.localhistory/

# BeatPulse healthcheck temp database 

# Node/npm
node_modules/
npm-debug.log
yarn-error.log
.pnpm-debug.log

# TailwindCSS
wwwroot/css/output.css
wwwroot/css/output.css.map
healthchecksdb

# SSDT specific files
*.dacpac

# Cake - Uncomment if you are using it
# tools/**
# !tools/packages.config

# End of core ignore list

.DS_Store
thumbs.db
